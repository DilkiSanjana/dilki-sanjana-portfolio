    <!-- ==========================================
         PROJECTS SECTION
         ========================================== -->
    <section id="projects" class="section-spacing">
      <div class="container">
        <div class="section-title-container text-start" data-aos="fade-up">
          <span class="section-subtitle">Portfolio</span>
          <h2 class="section-title">Featured Projects</h2>
        </div>
        
        <div class="row g-4">
          <!-- Project 1: Rental Management System -->
          <div class="col-lg-6" data-aos="fade-right" data-aos-delay="100">
            <div class="glass-card project-card">
              <div class="project-img-wrapper">
                <div class="project-img-overlay"></div>
                <img src="assets/images/project-rental.png" alt="Rental Management System Mockup Screen" class="project-img">
              </div>
              <div class="project-body">
                <h3 class="project-title text-primary">Rental Management System</h3>
                <p class="project-desc">
                  A mobile-based app targeting property listings and tenant-owner transactions. Designed to make the agreement generation process easier.
                </p>
                <ul class="project-feature-list">
                  <li><i class="bi bi-check-circle"></i> Mobile property searches and detail views.</li>
                  <li><i class="bi bi-check-circle"></i> Separate user roles for tenants and property owners.</li>
                  <li><i class="bi bi-check-circle"></i> Secured routes powered by JWT authorization.</li>
                  <li><i class="bi bi-check-circle"></i> Digital contract forms and agreement lifecycle tracking.</li>
                  <li><i class="bi bi-check-circle"></i> Controlled code base using Git repositories.</li>
                </ul>
                <div class="project-tags">
                  <span class="tag-badge">React Native</span>
                  <span class="tag-badge">Node.js</span>
                  <span class="tag-badge">Express.js</span>
                  <span class="tag-badge">MongoDB</span>
                </div>
                <div class="project-links">
                  <a href="https://github.com/DilkiSanjana" target="_blank" class="project-btn project-btn-outline">
                    <i class="fab fa-github"></i> Repository
                  </a>
                  <a href="#" class="project-btn project-btn-primary disabled" onclick="return false;">
                    <i class="bi bi-play-fill"></i> Live Demo (Offline)
                  </a>
                </div>
              </div>
            </div>
          </div>
          
          <!-- Project 2: Medical Appointment Scheduling System -->
          <div class="col-lg-6" data-aos="fade-left" data-aos-delay="200">
            <div class="glass-card project-card">
              <div class="project-img-wrapper">
                <div class="project-img-overlay"></div>
                <img src="assets/images/project-medical.png" alt="Medical Appointment System Mockup Web Screen" class="project-img">
              </div>
              <div class="project-body">
                <h3 class="project-title text-primary">Medical Appointment Scheduler</h3>
                <p class="project-desc">
                  A web application created to simplify clinic appointments, scheduling slots for doctors, and handling patient logs.
                </p>
                <ul class="project-feature-list">
                  <li><i class="bi bi-check-circle"></i> Clean UI dashboard for appointment booking logs.</li>
                  <li><i class="bi bi-check-circle"></i> CRUD operations for patient registration and medical details.</li>
                  <li><i class="bi bi-check-circle"></i> Java OOP patterns ensuring logical modular structures.</li>
                  <li><i class="bi bi-check-circle"></i> Local file handling storage for appointment entries.</li>
                </ul>
                <div class="project-tags">
                  <span class="tag-badge">Java</span>
                  <span class="tag-badge">Spring Boot</span>
                  <span class="tag-badge">HTML/CSS</span>
                  <span class="tag-badge">JavaScript</span>
                </div>
                <div class="project-links">
                  <a href="https://github.com/DilkiSanjana" target="_blank" class="project-btn project-btn-outline">
                    <i class="fab fa-github"></i> Repository
                  </a>
                  <a href="#" class="project-btn project-btn-primary disabled" onclick="return false;">
